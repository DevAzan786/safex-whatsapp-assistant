# =========================================================================
# SafeX FAQ Knowledge Base - Environment Variables Example Template
# Rename this file to '.env' and fill in your values. Do not commit '.env'.
# =========================================================================

# --- LLM Settings ---
# Gemini API Key (Required for query rewriting)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Database & Persistence ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=safex_faq
FAQ_DATASET_PATH=data/safex_faq_dataset.json
SQLITE_DB_PATH=data/safex_bot.db

# --- Cache Settings (Optional, Redis) ---
# If empty, the application will run without caching
REDIS_URL=
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.95

# --- Retrieval Hyperparameters ---
DENSE_TOP_K=10
SPARSE_TOP_K=10
RRF_K=60
RERANK_TOP_N=5

# --- Confidence Gate Settings ---
# Score threshold above which to consider a response confident
CONFIDENCE_THRESHOLD=0.70

# --- OpenWA WhatsApp Integration (Optional) ---
OPENWA_API_URL=http://localhost:2785
OPENWA_API_KEY=
OPENWA_SESSION_ID=default
